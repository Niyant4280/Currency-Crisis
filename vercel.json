{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/frontend/dist/$1" }
  ],
  "crons": [
    {
      "path": "/api/internal/cron",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "api/*.py": { "runtime": "vercel-python@0.1.1" }
  }
}
